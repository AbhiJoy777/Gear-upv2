rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function listingPath(listingId) {
      return /databases/$(database)/documents/listings/$(listingId);
    }

    function rentalPath(rentalId) {
      return /databases/$(database)/documents/rentals/$(rentalId);
    }

    function isAdmin() {
      return signedIn()
        && exists(userPath(request.auth.uid))
        && get(userPath(request.auth.uid)).data.role == 'admin';
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function affectedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function roleIsSafeOnCreate() {
      return !request.resource.data.keys().hasAny(['role'])
        || request.resource.data.role == 'user';
    }

    function roleIsNotSelfUpgraded() {
      return !affectedKeys().hasAny(['role'])
        || request.resource.data.role == resource.data.role;
    }

    function isRentalParticipant(data) {
      return signedIn()
        && (data.ownerId == request.auth.uid || data.renterId == request.auth.uid);
    }

    function rentalStatusIsAllowed(status) {
      return [
        'REQUESTED',
        'ACCEPTED',
        'PROOF_RECORDED',
        'LOGISTICS_PENDING',
        'PAYMENT_PENDING',
        'ACTIVE_RENTAL',
        'RETURN_DUE',
        'RETURNED',
        'CANCELLED'
      ].hasAny([status]);
    }

    function listingStatusIsAllowed(status) {
      return ['AVAILABLE', 'RESERVED', 'IN_USE'].hasAny([status]);
    }

    function reportStatusIsAllowed(status) {
      return ['open', 'reviewing', 'resolved', 'rejected'].hasAny([status]);
    }

    function verificationStatusIsAllowed(status) {
      return ['pending', 'verified', 'rejected'].hasAny([status]);
    }

    function rentalOwnershipIsImmutable() {
      return request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.renterId == resource.data.renterId
        && request.resource.data.gearId == resource.data.gearId;
    }

    function validRequestedRental() {
      return signedIn()
        && request.resource.data.keys().hasAll([
          'gearId',
          'gearTitle',
          'renterId',
          'ownerId',
          'startDate',
          'durationDays',
          'status',
          'totalPrice',
          'createdAt'
        ])
        && request.resource.data.renterId == request.auth.uid
        && request.resource.data.status == 'REQUESTED'
        && exists(listingPath(request.resource.data.gearId))
        && get(listingPath(request.resource.data.gearId)).data.ownerId == request.resource.data.ownerId
        && request.resource.data.ownerId != request.auth.uid;
    }

    function notificationOwnerIsSelf() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function notificationCreateIsSafe() {
      return signedIn()
        && request.resource.data.keys().hasAll(['userId', 'title', 'message', 'type', 'read', 'createdAt'])
        && request.resource.data.read == false;
    }

    function bookingNotificationIsSafe() {
      return notificationCreateIsSafe()
        && request.resource.data.type == 'request'
        && request.resource.data.actorId == request.auth.uid
        && request.resource.data.keys().hasAll(['listingId', 'actorId'])
        && exists(listingPath(request.resource.data.listingId))
        && get(listingPath(request.resource.data.listingId)).data.ownerId == request.resource.data.userId
        && request.resource.data.userId != request.auth.uid;
    }

    function rentalNotificationIsSafe() {
      return notificationCreateIsSafe()
        && ['return', 'cancelled'].hasAny([request.resource.data.type])
        && request.resource.data.actorId == request.auth.uid
        && request.resource.data.keys().hasAll(['rentalId', 'listingId', 'actorId'])
        && exists(rentalPath(request.resource.data.rentalId))
        && get(rentalPath(request.resource.data.rentalId)).data.gearId == request.resource.data.listingId
        && (
          get(rentalPath(request.resource.data.rentalId)).data.ownerId == request.auth.uid
          || get(rentalPath(request.resource.data.rentalId)).data.renterId == request.auth.uid
        )
        && (
          get(rentalPath(request.resource.data.rentalId)).data.ownerId == request.resource.data.userId
          || get(rentalPath(request.resource.data.rentalId)).data.renterId == request.resource.data.userId
        )
        && request.resource.data.userId != request.auth.uid;
    }

    function renterCanReserveListing() {
      return signedIn()
        && resource.data.status == 'AVAILABLE'
        && request.resource.data.status == 'RESERVED'
        && resource.data.ownerId != request.auth.uid
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']);
    }

    // Users: protect private profiles and prevent normal users from self-upgrading role.
    match /users/{uid} {
      allow get: if isSelf(uid) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSelf(uid) && roleIsSafeOnCreate();
      allow update: if isAdmin() || (isSelf(uid) && roleIsNotSelfUpgraded());
      allow delete: if false;
    }

    // Listings: authenticated marketplace reads; only owners manage listing content.
    match /listings/{listingId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && listingStatusIsAllowed(request.resource.data.status);
      allow update: if signedIn()
        && (
          (
            resource.data.ownerId == request.auth.uid
            && request.resource.data.ownerId == resource.data.ownerId
            && (!resource.data.keys().hasAny(['createdAt']) || request.resource.data.createdAt == resource.data.createdAt)
          )
          || renterCanReserveListing()
        );
      allow delete: if signedIn() && resource.data.ownerId == request.auth.uid;
    }

    // Rentals: only admins and the owner/borrower pair can see or advance a rental.
    match /rentals/{rentalId} {
      allow get, list: if isAdmin() || isRentalParticipant(resource.data);
      allow create: if validRequestedRental();
      allow update: if (isAdmin() || isRentalParticipant(resource.data))
        && rentalOwnershipIsImmutable()
        && rentalStatusIsAllowed(request.resource.data.status);
      allow delete: if false;
    }

    // Notifications: users can only read and mark their own notifications.
    match /notifications/{notificationId} {
      allow get, list: if notificationOwnerIsSelf();
      allow create: if bookingNotificationIsSafe() || rentalNotificationIsSafe();
      allow update: if notificationOwnerIsSelf()
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['read']);
      allow delete: if false;
    }

    // Reports: reporters create disputes; reporter, reported user, and admins can read; admins resolve.
    match /reports/{reportId} {
      allow get, list: if isAdmin()
        || (signedIn() && (
          resource.data.reporterId == request.auth.uid
          || resource.data.againstUserId == request.auth.uid
        ));
      allow create: if signedIn()
        && request.resource.data.reporterId == request.auth.uid
        && request.resource.data.status == 'open'
        && request.resource.data.keys().hasAll(['reporterId', 'reason', 'description', 'status', 'createdAt', 'updatedAt']);
      allow update: if isAdmin()
        && reportStatusIsAllowed(request.resource.data.status);
      allow delete: if false;
    }

    // Verification requests: users submit/read their own; admins review all.
    match /verificationRequests/{requestId} {
      allow get, list: if isAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if isAdmin()
        && request.resource.data.uid == resource.data.uid
        && verificationStatusIsAllowed(request.resource.data.status);
      allow delete: if false;
    }

    // Chats: booking chat remains limited to the rental owner and borrower.
    match /chats/{rentalId}/messages/{messageId} {
      allow read: if signedIn()
        && exists(rentalPath(rentalId))
        && isRentalParticipant(get(rentalPath(rentalId)).data);
      allow create: if signedIn()
        && exists(rentalPath(rentalId))
        && isRentalParticipant(get(rentalPath(rentalId)).data)
        && request.resource.data.rentalId == rentalId
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.keys().hasAll(['rentalId', 'senderId', 'senderName', 'text', 'createdAt']);
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
