{
  "entities": {
    "user": {
      "title": "User Profile",
      "description": "User account and wallet data",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "walletBalance": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "gear": {
      "title": "Professional Gear",
      "description": "Premium hardware listed for rent",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "pricePerDay": { "type": "number" },
        "status": { "type": "string" },
        "ownerId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "location": { "type": "string" },
        "logisticsType": { "type": "string" }
      }
    },
    "rental": {
      "title": "Gear Rental",
      "description": "Rental transaction and handshake state",
      "type": "object",
      "properties": {
        "gearId": { "type": "string" },
        "gearTitle": { "type": "string" },
        "renterId": { "type": "string" },
        "ownerId": { "type": "string" },
        "status": { "type": "string" },
        "totalPrice": { "type": "number" },
        "durationDays": { "type": "number" },
        "startDate": { "type": "string", "format": "date-time" },
        "actualStartTime": { "type": "string", "format": "date-time" },
        "proofOfLifeUrl": { "type": "string" },
        "returnLogistics": { "type": "string" },
        "logisticsType": { "type": "string" }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "user",
      "description": "User storage"
    },
    "listings/{gearId}": {
      "schema": "gear",
      "description": "Gear marketplace storage"
    },
    "rentals/{rentalId}": {
      "schema": "rental",
      "description": "Rental transaction storage"
    }
  }
}
